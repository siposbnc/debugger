{
  "name": "debugger-game",
  "private": true,
  "version": "0.4.0-dev",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "tsc && vite build --mode dev",
    "preview": "vite preview",
    "play": "tsc && vite build --mode dev --outDir dist-play && vite preview --outDir dist-play --port 4180 --open",
    "check": "tsc --noEmit",
    "deploy:test": "node scripts/deployTest.mjs",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
